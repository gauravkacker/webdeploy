{
  "name": "nextjs-template",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/src-electron/main.js",
  "scripts": {
    "dev": "npx --no-install next dev --turbo",
    "build": "next build && node scripts/postbuild.js",
    "build:dev": "node scripts/use-env.js dev && set NEXT_PUBLIC_BUILD_MODE=dev&& next build && node scripts/postbuild.js",
    "build:prod": "node scripts/use-env.js prod && set NEXT_PUBLIC_BUILD_MODE=prod&& next build && node scripts/postbuild.js",
    "build:server": "node scripts/use-env.js server && set NEXT_PUBLIC_DATA_MODE=server&& next build && node scripts/postbuild.js",
    "postbuild": "node scripts/postbuild.js",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop homeopms",
    "pm2:restart": "pm2 restart homeopms",
    "pm2:logs": "pm2 logs homeopms",
    "pm2:status": "pm2 status",
    "pm2:save": "pm2 save",
    "setup:lan:windows": "powershell -ExecutionPolicy RemoteSigned -File scripts/setup-autostart-windows.ps1",
    "setup:lan:linux": "bash scripts/setup-autostart-linux.sh",
    "setup:lan": "npm run setup:lan:linux || npm run setup:lan:windows",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "set NODE_ENV=development&& electron dist-electron/src-electron/main.js --dev",
    "electron:dev:full": "concurrently --kill-others-on-fail --names \"next,electron\" --prefix-colors \"cyan,yellow\" \"npm run dev\" \"npm run electron:dev\"",
    "electron:prebuild": "node scripts/clean-build.js && node -e \"const fs=require('fs');if(!fs.existsSync('license-seed.json')){fs.writeFileSync('license-seed.json',JSON.stringify({customer:{},license:{},plan:null},null,2));console.log('Created placeholder license-seed.json');}else{console.log('license-seed.json already exists, skipping.');}\"",
    "electron:build": "npm run electron:prebuild && npm run electron:compile && electron-builder",
    "electron:build:dev": "npm run build:dev && npm run electron:build -- --config.productName=HomeoPMS-Dev",
    "electron:build:prod": "npm run build:prod && npm run electron:build -- --config.productName=HomeoPMS",
    "electron:dist": "npm run build && npm run electron:build",
    "create-patch": "node scripts/create-patch.js"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.95",
    "@radix-ui/react-switch": "^1.2.6",
    "@xenova/transformers": "^2.6.5",
    "canvas": "^3.2.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "unzipper": "^0.12.3",
    "mammoth": "^1.6.0",
    "next": "^16.2.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.5.207",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sql.js": "^1.12.0",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^13.0.0",
    "whatsapp-web.js": "^1.34.6",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "com.homeopms.app",
    "productName": "HomeoPMS",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "your-github-username",
      "repo": "your-repo-name"
    },
    "extraResources": [
      {
        "from": "electron-resources/node-runtime.exe",
        "to": "node-runtime.exe"
      },
      {
        "from": ".next/standalone",
        "to": "next-server",
        "filter": ["**/*"]
      },
      {
        "from": "whatsapp-server.js",
        "to": "next-server/whatsapp-server.js"
      },
      {
        "from": "license-seed.json",
        "to": "license-seed.json",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "dist-electron/**/*",
      ".next/static/**/*",
      "public/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/onnxruntime-node/**/*",
      "!node_modules/pdfjs-dist/**/*",
      "!node_modules/tesseract.js/**/*",
      "!node_modules/tesseract.js-core/**/*",
      "!node_modules/@next/**/*",
      "!node_modules/.cache/**/*",
      "!.data/**/*",
      "!.whatsapp-session/**/*",
      "!.test-license-backups/**/*",
      "!.test-license-storage-backup/**/*"
    ],
    "asarUnpack": [
      "node_modules/sql.js/**/*",
      "node_modules/canvas/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/@napi-rs/**/*",
      ".next/standalone/**/*",
      ".next/standalone/node_modules/**/*",
      "node_modules/whatsapp-web.js/**/*",
      "node_modules/puppeteer/**/*",
      "node_modules/puppeteer-core/**/*",
      "node_modules/ws/**/*",
      "node_modules/express/**/*",
      "node_modules/qrcode/**/*"
    ]
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/electron": "^1.4.38",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.9",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-store": "^10.0.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.0",
    "jest": "^30.2.0",
    "lightningcss": "^1.32.0",
    "tailwindcss": "^4.1.17",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
